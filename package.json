{
  "name": "openwind",
  "version": "1.0.0",
  "description": "Security-first persistent cognitive kernel — your world, always with you.",
  "type": "module",
  "author": {
    "name": "Teo Bouancheau",
    "email": "t.bouancheau@gmail.com",
    "url": "https://github.com/teobouancheau"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/teobouancheau/openwind.git"
  },
  "homepage": "https://github.com/teobouancheau/openwind",
  "bugs": {
    "url": "https://github.com/teobouancheau/openwind/issues"
  },
  "keywords": [
    "cognitive-kernel",
    "knowledge-graph",
    "mcp",
    "ai",
    "personal-assistant",
    "security-first"
  ],
  "bin": {
    "openwind": "./dist/index.mjs"
  },
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown src/cli.ts src/index.ts --format esm --dts --define.OPENWIND_VERSION=\"'$npm_package_version'\"",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:security": "grep -rn 'child_process\\|.exec(\\|eval(' src/ && exit 1 || echo 'No banned patterns'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.76.0",
    "@clack/prompts": "1.0.1",
    "@huggingface/transformers": "3.8.1",
    "@modelcontextprotocol/sdk": "1.26.0",
    "better-sqlite3": "12.6.2",
    "commander": "14.0.3",
    "grammy": "1.40.0",
    "imapflow": "1.2.9",
    "json5": "2.2.3",
    "nanoid": "5.1.6",
    "nodemailer": "8.0.1",
    "ogg-opus-decoder": "1.7.3",
    "openai": "6.22.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.10.13",
    "@types/nodemailer": "7.0.10",
    "prettier": "3.8.1",
    "tsdown": "0.20.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "license": "MIT"
}
