{
  "name": "opensauria-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "OpenSauria monorepo — security-first personal AI operating system.",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "author": {
    "name": "Teo Bouancheau",
    "email": "t.bouancheau@gmail.com",
    "url": "https://github.com/teobouancheau"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/teobouancheau/opensauria.git"
  },
  "homepage": "https://github.com/teobouancheau/opensauria",
  "bugs": {
    "url": "https://github.com/teobouancheau/opensauria/issues"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "build:daemon": "turbo run build --filter=@opensauria/daemon",
    "build:desktop": "turbo run build --filter=opensauria-desktop",
    "dev:daemon": "pnpm --filter @opensauria/daemon run dev",
    "dev:desktop": "pnpm --filter opensauria-desktop run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "3.8.1",
    "turbo": "2.5.4",
    "typescript": "5.9.3"
  },
  "license": "MIT"
}
