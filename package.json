{
  "name": "openwind-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "OpenWind monorepo — security-first personal AI operating system.",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "author": {
    "name": "Teo Bouancheau",
    "email": "t.bouancheau@gmail.com",
    "url": "https://github.com/teobouancheau"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/teobouancheau/openwind.git"
  },
  "homepage": "https://github.com/teobouancheau/openwind",
  "bugs": {
    "url": "https://github.com/teobouancheau/openwind/issues"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "build:daemon": "turbo run build --filter=@openwind/daemon",
    "build:desktop": "turbo run build --filter=openwind-desktop",
    "dev:daemon": "pnpm --filter @openwind/daemon run dev",
    "dev:desktop": "pnpm --filter openwind-desktop run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "3.8.1",
    "turbo": "2.5.4",
    "typescript": "5.9.3"
  },
  "license": "MIT"
}
