{
  "name": "openwind",
  "version": "1.0.0",
  "description": "Security-first persistent cognitive kernel — your world, always with you.",
  "type": "module",
  "author": {
    "name": "Teo Bouancheau",
    "email": "t.bouancheau@gmail.com",
    "url": "https://github.com/teobouancheau"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/teobouancheau/openwind.git"
  },
  "homepage": "https://github.com/teobouancheau/openwind",
  "bugs": {
    "url": "https://github.com/teobouancheau/openwind/issues"
  },
  "keywords": [
    "cognitive-kernel",
    "knowledge-graph",
    "mcp",
    "ai",
    "personal-assistant",
    "security-first"
  ],
  "bin": {
    "openwind": "./dist/index.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown src/cli.ts src/index.ts --format esm --dts --define.OPENWIND_VERSION=\"'$npm_package_version'\"",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:security": "grep -rn 'child_process\\|.exec(\\|eval(' src/ && exit 1 || echo 'No banned patterns'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.39.0",
    "@clack/prompts": "0.9.1",
    "@huggingface/transformers": "3.4.1",
    "@modelcontextprotocol/sdk": "1.26.0",
    "better-sqlite3": "11.8.1",
    "commander": "13.1.0",
    "grammy": "1.35.0",
    "json5": "2.2.3",
    "nanoid": "5.1.5",
    "openai": "4.85.0",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.13.4",
    "prettier": "3.5.3",
    "tsdown": "0.20.3",
    "tsx": "4.19.3",
    "typescript": "5.7.3",
    "vitest": "3.0.5"
  },
  "license": "MIT"
}
