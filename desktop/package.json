{
  "name": "openwind-desktop",
  "version": "1.0.0",
  "description": "OpenWind — Setup & System Tray",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "icons": "node scripts/copy-icons.js",
    "prebuild": "npm run icons",
    "dev": "npm run icons && tsc && rm -rf dist/ui && cp -r src/ui dist/ui && electron-forge start",
    "build": "tsc && rm -rf dist/ui && cp -r src/ui dist/ui && electron-forge make",
    "package": "tsc && rm -rf dist/ui && cp -r src/ui dist/ui && electron-forge package"
  },
  "dependencies": {
    "electron-squirrel-startup": "1.0.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.6.0",
    "@electron-forge/maker-deb": "7.6.0",
    "@electron-forge/maker-dmg": "7.6.0",
    "@electron-forge/maker-rpm": "7.6.0",
    "@electron-forge/maker-squirrel": "7.6.0",
    "@electron-forge/maker-zip": "7.6.0",
    "electron": "33.3.1",
    "lucide-static": "^0.574.0",
    "simple-icons": "^16.9.0",
    "typescript": "5.7.3"
  }
}
