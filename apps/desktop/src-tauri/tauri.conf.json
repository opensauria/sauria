{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sauria",
  "identifier": "ai.sauria.desktop",
  "build": {
    "beforeDevCommand": "pnpm run dev:vite",
    "beforeBuildCommand": "pnpm run native-deps && pnpm run sign-native-deps && pnpm run build:vite",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost blob: data: https:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg", "nsis", "deb", "appimage"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"],
    "resources": {
      "../../daemon/dist/": "daemon",
      "../native-deps/": "node_modules",
      "build-hash.txt": "."
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "nsis": {}
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["sauria"]
      }
    },
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": ["https://github.com/opensauria/sauria/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxOTg5M0RDMjJEQTJBQjAKUldTd0t0b2kzSk9Zd1dQQW0xVkszMDFhZXZ2SC9YOXIzRUlxa2YwUWhSUTIzbFMrdXFwM0s0aSsK"
    }
  }
}
