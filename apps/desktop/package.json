{
  "name": "openwind-desktop",
  "version": "1.0.0",
  "description": "OpenWind — Setup & System Tray",
  "private": true,
  "main": ".vite/build/app.js",
  "scripts": {
    "icons": "node scripts/copy-icons.js",
    "dev": "pnpm run icons && electron-forge start",
    "build": "pnpm run icons && electron-forge package",
    "package": "pnpm run icons && electron-forge package",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openwind/config": "workspace:*",
    "@openwind/design-tokens": "workspace:*",
    "@openwind/ipc-protocol": "workspace:*",
    "@openwind/types": "workspace:*",
    "@openwind/vault": "workspace:*",
    "electron-squirrel-startup": "1.0.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.1",
    "@electron-forge/maker-deb": "7.11.1",
    "@electron-forge/maker-dmg": "7.11.1",
    "@electron-forge/maker-rpm": "7.11.1",
    "@electron-forge/maker-squirrel": "7.11.1",
    "@electron-forge/maker-zip": "7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "electron": "40.4.1",
    "lucide-static": "0.574.0",
    "simple-icons": "16.9.0",
    "typescript": "5.9.3",
    "vite": "^7.3.1"
  }
}
