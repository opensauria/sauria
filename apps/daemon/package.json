{
  "name": "@sauria/cli",
  "version": "2026.309.0",
  "description": "Sauria CLI — your AI workforce.",
  "type": "module",
  "bin": {
    "sauria": "./dist/index.mjs"
  },
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist/**/*.mjs",
    "dist/**/*.d.mts",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint:security": "grep -rn 'child_process\\|.exec(\\|eval(' src/ && exit 1 || echo 'No banned patterns'",
    "prepack": "cp ../../LICENSE ../../NOTICE ../../README.md .",
    "postpack": "rm -f LICENSE NOTICE README.md"
  },
  "dependencies": {
    "better-sqlite3": "12.6.2"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "0.76.0",
    "@clack/prompts": "1.0.1",
    "@modelcontextprotocol/sdk": "1.26.0",
    "@sauria/config": "workspace:*",
    "@sauria/ipc-protocol": "workspace:*",
    "@sauria/types": "workspace:*",
    "@sauria/vault": "workspace:*",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.10.13",
    "@types/nodemailer": "7.0.10",
    "commander": "14.0.3",
    "grammy": "1.40.0",
    "imapflow": "1.2.9",
    "json5": "2.2.3",
    "nanoid": "5.1.6",
    "nodemailer": "8.0.1",
    "openai": "6.22.0",
    "tsdown": "0.20.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18",
    "zod": "4.3.6"
  },
  "author": {
    "name": "Teo Bouancheau",
    "email": "116342837+teobouancheau@users.noreply.github.com",
    "url": "https://github.com/teobouancheau"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/opensauria/sauria.git",
    "directory": "apps/daemon"
  },
  "homepage": "https://github.com/opensauria/sauria",
  "bugs": {
    "url": "https://github.com/opensauria/sauria/issues"
  },
  "license": "AGPL-3.0-or-later"
}
