{
  "name": "@sauria/design-tokens",
  "version": "1.0.0",
  "private": true,
  "author": "Teo Bouancheau <t.bouancheau@gmail.com>",
  "license": "BUSL-1.1",
  "repository": { "type": "git", "url": "https://github.com/teobouancheau/sauria.git", "directory": "packages/design-tokens" },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./generated/tokens.css",
    "./tokens.json": "./generated/tokens.json"
  },
  "scripts": {
    "generate": "node --import tsx scripts/generate.ts",
    "build": "pnpm run generate && tsc",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsx": "4.19.4",
    "typescript": "5.9.3"
  }
}
